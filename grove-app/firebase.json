{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        ".secret.local",
        ".env",
        ".env.*",
        "*.local",
        "*service-account*.json",
        "*serviceAccount*.json",
        "credentials*.json",
        "secrets*.json",
        "*.pem",
        "*.key",
        "*.p8",
        "*.p12"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "auth": {
    "providers": {
      "anonymous": false,
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "Grove",
        "supportEmail": "support@grove.app",
        "authorizedRedirectUris": ["http://localhost:5173"]
      }
    }
  }
}
