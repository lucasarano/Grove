# Copy to .env and fill in public Firebase client config. Never commit .env.
# VITE_* values are bundled into the browser, so do not put provider or Stripe
# secret keys here.
# Provider API keys are Firebase Functions secrets:
#   firebase functions:secrets:set ANTHROPIC_API_KEY
#   firebase functions:secrets:set OPENAI_API_KEY
# Billing keys are also Firebase Functions secrets:
#   firebase functions:secrets:set STRIPE_SECRET_KEY
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Google Analytics (GA4) - from Firebase console > Project settings > Your apps
VITE_FIREBASE_MEASUREMENT_ID=

# Optional for local function emulators, e.g. http://127.0.0.1:5001/<project>/us-central1
VITE_FIREBASE_FUNCTIONS_ORIGIN=
